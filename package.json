{
  "name": "backendbillarenlinea",
  "version": "1.0.0",
  "description": "este es backend de mi emprendimiento de billar en linea",
  "license": "ISC",
  "author": "Jeison Vargas",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "start": "npx tsx src/app.ts",
    "dev": "nodemon --watch src --ext ts --exec \"npx tsx src/app.ts\"",
    "build": "tsc",
    "db:clear": "node scripts/clear-database.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "npx tsx src/utils/seedData.ts",
    "seed:watch": "nodemon --watch src/utils/seedData.ts --ext ts --exec \"npx tsx src/utils/seedData.ts\"",
    "verify": "npx tsx src/utils/verifyData.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
